{
  "name": "claude-remote",
  "private": true,
  "workspaces": ["server", "client", "shared"],
  "scripts": {
    "predev": "lsof -ti :${PORT:-5554} | xargs kill -9 2>/dev/null || true",
    "dev": "env-cmd concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "cd server && bun run dev",
    "dev:client": "cd client && bun run dev",
    "build": "cd client && bun run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "env-cmd": "^11.0.0"
  }
}
